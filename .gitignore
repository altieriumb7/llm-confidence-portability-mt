# Python environments
.venv/
venv/
env/

# Editors / IDEs
.idea/
.vscode/

# Python caches and build artifacts
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/

# OS junk
.DS_Store
Thumbs.db

# Secrets / credentials
.env
*.pem
*.key
google*.json
kaggle.json
